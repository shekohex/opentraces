{
  "name": "clanker-share",
  "version": "0.2.0",
  "description": "Browse, export & share Claude Code, Codex & OpenCode sessions",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "clanker-share": "./bin.mjs"
  },
  "files": [
    "bin.mjs",
    "index.ts",
    "viewer.js",
    "viewer.css"
  ],
  "scripts": {
    "build:site": "bun run build-site.ts",
    "deploy": "bun run build:site && bunx wrangler pages deploy site --project-name clanker-share --commit-dirty=true"
  },
  "keywords": [
    "claude",
    "codex",
    "opencode",
    "session",
    "export",
    "share",
    "tui"
  ],
  "license": "MIT",
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "puppeteer": "^24.40.0"
  }
}
