{
  "name": "opentraces",
  "version": "0.2.0",
  "description": "Browse, export & share Claude Code, Codex, OpenCode & Pi Coding Agent sessions",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "opentraces": "./bin.mjs"
  },
  "files": [
    "bin.mjs",
    "public",
    "public-url.js",
    "server.mjs",
    "build-site.ts",
    "generate-og.ts",
    "index.ts",
    "site-template.html",
    "viewer.js",
    "viewer.css",
    "site"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:site",
    "build:site": "tsx build-site.ts",
    "vendor:font": "node scripts/vendor-nerd-font.mjs",
    "dev": "tsx watch server.mjs",
    "dev:cli": "tsx watch index.ts",
    "dev:site": "tsx watch build-site.ts",
    "prepack": "npm run build",
    "serve": "node server.mjs",
    "start": "node server.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "claude",
    "codex",
    "opencode",
    "session",
    "export",
    "share",
    "tui"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.14",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.0.0",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3"
  }
}
